---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = "w-5 h-5" } = Astro.props;
---

{name === 'code' && (
  <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 border bg-blue-50 border-blue-100 text-blue-600">
    <svg class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
    </svg>
  </div>
)}

{name === 'wrench' && (
  <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 border bg-indigo-50 border-indigo-100 text-indigo-600">
    <svg class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
    </svg>
  </div>
)}

{name === 'globe' && (
  <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 border bg-purple-50 border-purple-100 text-purple-600">
    <svg class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
    </svg>
  </div>
)}