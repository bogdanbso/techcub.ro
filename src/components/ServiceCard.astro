---
import Icon from './Icon.astro';

interface Props {
  titlu: string;
  rezumat: string;
  slug: string;
  icon: string;
}

const { titlu, rezumat, slug, icon } = Astro.props;
---

<a 
  href={`/servicii/${slug}`} 
  class="p-6 rounded-2xl border border-black/10 hover:border-black/30 transition flex items-start gap-4 group bg-white"
>
  <Icon name={icon} />
  <div>
    <h3 class="text-xl font-bold group-hover:underline">{titlu}</h3>
    <p class="opacity-70 mt-1 text-sm">{rezumat}</p>
  </div>
</a>