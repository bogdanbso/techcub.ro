---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404 - Pagina nu a fost găsită" description="Pagina căutată nu există sau a fost mutată." noindex={true}>
  <section class="p-8 max-w-xl mx-auto text-center py-20">
    <h1 class="text-6xl font-bold">404</h1>
    <p class="text-xl opacity-70 mt-4">Pagina pe care o cauți nu există.</p>
    <div class="mt-8">
      <a href="/" class="inline-block border px-6 py-3 rounded-lg hover:opacity-70 transition">
        Înapoi la prima pagină
      </a>
    </div>
  </section>
</PageLayout>
