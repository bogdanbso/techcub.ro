---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const servicii = await getCollection('servicii');
const serviciiOrdonate = servicii.sort((a, b) => a.data.ordine - b.data.ordine);
---

<PageLayout title="Acasă" description="Site-uri și soluții IT construite pe măsură.">
  <section class="p-8 max-w-4xl mx-auto py-16 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">
      Soluții digitale și servicii IT
    </h1>
    <p class="text-lg opacity-70 mt-4 max-w-2xl mx-auto">
      Dezvoltare web rapidă, mentenanță tehnică și infrastructură IT stabilă pentru afacerea ta.
    </p>
  </section>

  <section class="max-w-2xl mx-auto p-8 border-t border-black/10">
    <h2 class="text-2xl font-bold mb-3">Salut, sunt Bogdan</h2>
    <p class="opacity-80 leading-relaxed">
      Pasiunea mea pentru tehnologie s-a transformat în dorința de a ajuta afacerile și persoanele fizice să aibă o prezență digitală impecabilă și echipamente funcționale. Mă concentrez pe soluții curate, fără aplicații greoaie sau complicații inutile, oferind sfaturi sincere și suport direct.
    </p>
  </section>

  <section id="servicii" class="max-w-2xl mx-auto p-8 border-t border-black/10">
    <h2 class="text-2xl font-bold mb-6">Servicii</h2>
    <div class="flex flex-col gap-4">
      {serviciiOrdonate.map((serviciu) => (
        <ServiceCard 
          titlu={serviciu.data.titlu}
          rezumat={serviciu.data.rezumat}
          slug={serviciu.id}
          icon={serviciu.data.icon}
        />
      ))}
    </div>
  </section>

  <section class="max-w-2xl mx-auto p-8 border-t border-black/10">
    <h2 class="text-2xl font-bold mb-6">De ce să lucrezi cu mine</h2>
    <div class="flex flex-col gap-5">
      <div>
        <h3 class="font-semibold">Comunicare directă, fără intermediari</h3>
        <p class="opacity-70 mt-1">Vorbești direct cu persoana care execută lucrarea, nu cu un dispecer care transmite mai departe.</p>
      </div>
      <div>
        <h3 class="font-semibold">Prețuri clare, spuse dinainte</h3>
        <p class="opacity-70 mt-1">Știi exact cât costă înainte să încep, fără reparații "descoperite" ulterior fără acordul tău.</p>
      </div>
      <div>
        <h3 class="font-semibold">Cod modern & site-uri ultra-rapide</h3>
        <p class="opacity-70 mt-1">Construiesc pe tehnologii moderne, cu puțin JavaScript și o suprafață redusă de atac.</p>
      </div>
      <div>
        <h3 class="font-semibold">Locație & Flexibilitate</h3>
        <p class="opacity-70 mt-1">Prezență fizică în Cluj-Napoca pentru intervenții hardware și suport la distanță oriunde în țară.</p>
      </div>
    </div>
  </section>

  <section class="max-w-2xl mx-auto p-8 border-t border-black/10 text-center">
    <h2 class="text-2xl font-bold mb-4">Hai să discutăm</h2>
    <p class="opacity-70 mb-6">Spune-mi ce probleme ai sau ce vrei să construiești, și îți răspund cu o soluție concretă.</p>
    <a href="/contact" class="inline-block bg-[var(--color-ink)] text-[var(--color-paper)] px-6 py-3 rounded-lg font-medium hover:opacity-90 transition">
      Cere o ofertă
    </a>
  </section>
</PageLayout>
