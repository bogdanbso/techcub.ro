---
import PageLayout from '../layouts/PageLayout.astro';
import { BRAND_NAME, CONTACT_EMAIL, CONTACT_PHONE } from '../lib/brand';
---

<PageLayout title="Contact" description="Scrie-mi sau sună-mă pentru orice întrebare.">
  <section class="p-8 max-w-xl mx-auto">
    <h1 class="text-4xl font-bold">Contact</h1>
    <p class="text-lg opacity-70 mt-4">
      Scrie-mi sau sună-mă, îți răspund cât de repede pot.
    </p>

    <div class="mt-8 space-y-2">
      <p>
        Email: <a href={`mailto:${CONTACT_EMAIL}`} class="underline">{CONTACT_EMAIL}</a>
      </p>
      <p>
        Telefon: <a href={`tel:${CONTACT_PHONE}`} class="underline">{CONTACT_PHONE}</a>
      </p>
    </div>
  </section>
</PageLayout>